PORT=3333
HOST=127.0.0.1
NODE_ENV=production
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
SESSION_DAYS=30
APP_PACKAGE_NAME=com.astratechnologies.nexoride
APP_NAME=NEXO Ride
ADMIN_MOBILE=6295192839
ADMIN_EMAIL=bappa.roysm@gmail.com
ADMIN_TEMP_PASSWORD=admin@123
SUPPORT_MOBILE=9749983737
SUPPORT_EMAIL=babairoykalma@gmail.com

# Public production URL for VPS deployment
SERVER_URL=https://ride.nexoofficial.in
DOMAIN_NAME=ride.nexoofficial.in
DEPLOY_PROVIDER=VPS
DEPLOY_BRANCH=main
SSL_CONFIGURED=true

# Security - MUST change before public launch
APP_SECRET=change_this_long_random_secret_min_32_chars
JWT_SECRET=change_this_long_random_jwt_secret_min_32_chars
SECURITY_ADMIN_2FA=false
SECURITY_IP_ALLOWLIST=
LOGIN_RATE_LIMIT_PER_MINUTE=8
ADMIN_SESSION_DAYS=7

# Database - current stable mode is local JSON; later migrate to PostgreSQL
DATABASE_URL=
KYC_STORAGE_MODE=LOCAL_FILE
STORAGE_PROVIDER=LOCAL_FILE
MAX_UPLOAD_MB=10

# Map navigation production settings
MAP_PROVIDER=DEMO
NAVIGATION_PROVIDER=GOOGLE_WEB
MAPPLS_API_KEY=
GOOGLE_MAPS_API_KEY=

# OTP/Auth settings
OTP_PROVIDER=DEMO
DEMO_OTP=123456
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
MAX_OTP_PER_MOBILE_PER_HOUR=5
FIREBASE_PROJECT_ID=
MSG91_AUTH_KEY=
TWOFACTOR_API_KEY=

# Payment settings
PAYMENT_PROVIDER=DEMO
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
MANUAL_UPI_ID=

# Push / Firebase settings
PUSH_PROVIDER=DEMO
FCM_SERVER_KEY=
FCM_WEB_VAPID_KEY=
FIREBASE_MESSAGING_SENDER_ID=

# V54 PWA cache helper
APP_CACHE_VERSION=153v54

# Passenger Google Login
GOOGLE_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://ride.nexoofficial.in/api/auth/google/callback

# Razorpay Payment Gateway
RAZORPAY_ENABLED=false
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_COMPANY_NAME=NEXO Ride
